model RentalOrder {
    id          String       @id @default(uuid())
    customerId  String
    customer    User         @relation(fields: [customerId], references: [id])
    gearId      String
    gear        Gear         @relation(fields: [gearId], references: [id])
    quantity    Decimal
    totalAmount Decimal
    startDate   DateTime
    endDate     DateTime
    status      RentalStatus
    payment     Payment?
    review      Review?
    createdAt   DateTime     @default(now())
    updatedAt   DateTime     @updatedAt

    @@index([gearId])
    @@index([customerId])
    @@map("rentalOrders")
}
